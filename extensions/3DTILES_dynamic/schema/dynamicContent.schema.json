{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dynamicContent.schema.json",
  "title": "Content for 3DTILES_dynamic",
  "description": "Defines the structure of 3D Tiles content for the 3DTILES_dynamic extension",
  "type": "object",
  "properties": {
    "dynamicContents": {
      "type": "array",
      "items": {
          "$ref": "dynamicContentItem.schema.json"
      },
      "minItems": 1
    }
  },
  "required": [
    "dynamicContents"
  ]
}