{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "3DTILES_dynamic_extension.json",
  "title": "3DTILES_dynamic extension",
  "description": "Defines the structure of the extension object that is stored as the 3DTILES_dynamic extension in a tileset JSON",
  "type": "object",
  "properties": {
    "dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "keySet": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "keySet"
        ]
      }
    }
  },
  "required": [
    "dimensions"
  ]
}