{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "conditionalContent.schema.json",
  "title": "Content for 3DTILES_content_conditional",
  "description": "Defines the structure of 3D Tiles content for the 3DTILES_content_conditional extension",
  "type": "object",
  "properties": {
    "conditionalContents": {
      "type": "array",
      "items": {
          "$ref": "conditionalContentItem.schema.json"
      },
      "minItems": 1
    }
  },
  "required": [
    "conditionalContents"
  ]
}